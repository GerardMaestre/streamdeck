# Copia este archivo como .env y rellena tus credenciales para activar Domótica y Discord.
# Puedes poner .env en:
# 1) La misma carpeta del .exe (prioridad más alta)
# 2) %APPDATA%/mi-streamdeck/.env

# --- Tuya / Domótica ---
TUYA_ACCESS_KEY=
TUYA_SECRET_KEY=

# --- Discord RPC ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost
