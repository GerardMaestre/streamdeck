{
  "name": "mi-streamdeck",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-builder install-app-deps",
    "build": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.3",
    "audio-mixer": "^2.1.4",
    "discord-rpc": "^4.0.1",
    "express": "^5.2.1",
    "loudness": "^0.4.2",
    "native-sound-mixer": "^3.4.6-win",
    "open": "^11.0.0",
    "robotjs": "^0.7.0",
    "screenshot-desktop": "^1.15.3",
    "socket.io": "^4.8.3",
    "win-audio": "^3.0.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gerardmaestre.streamdeckpro",
    "productName": "Stream Deck Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "controllers/**/*",
      "icon.png"
    ],
    "extraResources": [
      "config.json",
      "mis_scripts/**/*",
      "icon.png"
    ],
    "asarUnpack": [
      "**/node_modules/robotjs/**/*",
      "**/node_modules/native-sound-mixer/**/*",
      "**/node_modules/win-audio/**/*",
      "**/node_modules/audio-mixer/**/*",
      "**/node_modules/loudness/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Stream Deck Pro"
    }
  }
}