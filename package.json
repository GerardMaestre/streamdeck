{
  "name": "mi-streamdeck",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node esbuild.config.js && electron .",
    "dev": "node esbuild.config.js --watch",
    "bundle": "node esbuild.config.js",
    "rebuild": "electron-builder install-app-deps",
    "build": "node esbuild.config.js && electron-builder --win",
    "pm2-start": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 stop streamdeck-pro",
    "pm2-restart": "pm2 restart streamdeck-pro",
    "postinstall": "patch-package",
    "check": "node --check server.js && node --check main.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tuya/tuya-connector-nodejs": "^2.1.2",
    "compression": "^1.8.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "native-sound-mixer": "^3.4.6-win",
    "open": "^8.4.2",
    "screenshot-desktop": "^1.15.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "pm2": "^5.3.0"
  },
  "build": {
    "appId": "com.gerardmaestre.streamdeckpro",
    "productName": "Stream Deck Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "backend/**/*"
    ],
    "extraResources": [
      ".env",
      "config.json",
      "scripts/**/*",
      "frontend/**/*",
      "data/**/*",
      "icon.png"
    ],
    "asarUnpack": [
      "**/node_modules/native-sound-mixer/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Stream Deck Pro"
    }
  }
}
